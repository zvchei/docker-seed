{
    "description": "Visual Studio Code",
    "apt_packages": ["gpg", "git"],
    "assets": [
        {
            "url": "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-x64",
            "filename": "vscode.deb"
        }
    ],
    "volumes": {
        "vscode": ".vscode",
        "vscode-server": ".vscode-server",
        "cache": ".cache",
        "env": "env"
    },
    "ports": ["8080:8080"],
    "cmd": [
        "code",
        "serve-web",
        "--host",
        "0.0.0.0",
        "--port",
        "8080",
        "--without-connection-token"
    ]
}
