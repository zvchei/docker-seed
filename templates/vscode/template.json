{
    "description": "Visual Studio Code",
    "apt_packages": ["curl", "gpg", "git"],
    "volumes": {
        "vscode": ".vscode",
        "vscode-server": ".vscode-server",
        "cache": ".cache",
        "env": "env"
    },
    "ports": ["8080:8080"],
    "cmd": [
        "code",
        "serve-web",
        "--host",
        "0.0.0.0",
        "--port",
        "8080",
        "--without-connection-token"
    ]
}
