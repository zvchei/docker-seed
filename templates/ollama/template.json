{
    "description": "Ollama LLM server",
    "hostname": "ollama",
    "apt_packages": ["curl", "zstd"],
    "assets": [
        {
            "url": "https://ollama.com/install.sh",
            "filename": "ollama-install.sh"
        }
    ],
    "ports": ["11434:11434"],
    "volumes": {
        "ollama_storage": ".ollama"
    },
    "entrypoint": ["ollama"],
    "cmd": ["serve"]
}
